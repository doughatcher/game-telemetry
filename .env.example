# DnD Stage — environment config example
# Copy this file to .env and fill in your values.

# ── Ollama (local AI) ──
# Any model that follows structured output instructions well.
# Tested: gemma4:e4b (fast, fits in 12GB VRAM), gemma4-26b (slower, better quality)
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# ── Speaches STT (speech-to-text) ──
# OpenAI-compatible /v1/audio/transcriptions endpoint.
# https://github.com/speaches-ai/speaches — runs locally via Docker.
SPEACHES_BASE=http://localhost:8000

# ── Server ──
HOST=0.0.0.0
PORT=3200

# ── GitHub release publishing ──
# Repo to push session archives and create releases in.
# Requires GITHUB_TOKEN with repo write access (or gh CLI already authenticated).
GITHUB_REPO=doughatcher/game-telemetry
GITHUB_TOKEN=

# ── AI update tuning ──
# STATE: fast pass — extracts HP, enemies, conditions (~4s at 50 t/s)
STATE_TRIGGER_CHARS=80    # new transcript chars before triggering
STATE_DEBOUNCE_SECS=6     # wait after last trigger before running

# PANEL: full pass — scene, story, map, next-steps, decisions (~20s at 50 t/s)
PANEL_TRIGGER_CHARS=300
PANEL_DEBOUNCE_SECS=12
